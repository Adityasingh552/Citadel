# Supabase PostgreSQL — get from your Supabase project settings
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase Auth & API
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# YOLO26 ONNX model configuration
# MODEL_PATH: Local path where model will be stored (default: ./models/model.onnx)
# MODEL_URL: HuggingFace URL to auto-download if model doesn't exist locally
MODEL_PATH=./models/model.onnx
MODEL_URL=https://huggingface.co/gopesh353/citadel/resolve/main/exp-2.onnx

CONFIDENCE_THRESHOLD=0.7
EVIDENCE_DIR=./evidence
UPLOADS_DIR=./uploads

# Heroku deployment: set this to your Vercel frontend URL
# FRONTEND_URL=https://your-app.vercel.app

# Heroku deployment: base URL for public links (e.g. for Telegram alerts)
# CITADEL_BASE_URL=https://your-app.herokuapp.com

# Twilio emergency voice calls
# Toggle independently for manual uploads vs live CCTV monitors
TWILIO_ENABLED_MANUAL=false
TWILIO_ENABLED_CCTV=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
EMERGENCY_CONTACT_NUMBER=+91XXXXXXXXXX
# Minimum seconds between calls (default 300 = 5 min); prevents call flooding from CCTV
TWILIO_CALL_COOLDOWN_SECONDS=300
# Camera list cache — hours before Iowa ArcGIS / Caltrans CSV is re-fetched from network.
# Set to 0 to always refetch on startup.
CAMERA_LIST_CACHE_TTL_HOURS=24

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

DATABASE_URL=sqlite:///./citadel.db
# Path to YOLO26 ONNX model file (required)
MODEL_PATH=/path/to/yolo26.onnx
CONFIDENCE_THRESHOLD=0.7
EVIDENCE_DIR=./evidence
UPLOADS_DIR=./uploads
ADMIN_USERNAME=
ADMIN_PASSWORD=
JWT_SECRET=

# Heroku deployment: set this to your Vercel frontend URL
# FRONTEND_URL=https://your-app.vercel.app

# Heroku deployment: base URL for public links (e.g. for Telegram alerts)
# CITADEL_BASE_URL=https://your-app.herokuapp.com

# Twilio emergency voice calls
# Toggle independently for manual uploads vs live CCTV monitors
TWILIO_ENABLED_MANUAL=false
TWILIO_ENABLED_CCTV=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
EMERGENCY_CONTACT_NUMBER=+91XXXXXXXXXX
# Minimum seconds between calls (default 300 = 5 min); prevents call flooding from CCTV
TWILIO_CALL_COOLDOWN_SECONDS=300
# Camera list cache — hours before Iowa ArcGIS / Caltrans CSV is re-fetched from network.
# Set to 0 to always refetch on startup.
CAMERA_LIST_CACHE_TTL_HOURS=24

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

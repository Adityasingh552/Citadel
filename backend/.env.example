DATABASE_URL=sqlite:///./citadel.db
MODEL_NAME=gopesh353/traffic-accident-detection-detr
CONFIDENCE_THRESHOLD=0.7
EVIDENCE_DIR=./evidence
UPLOADS_DIR=./uploads
ADMIN_USERNAME=
ADMIN_PASSWORD=
JWT_SECRET=

# Twilio emergency voice calls
# Toggle independently for manual uploads vs live CCTV monitors
TWILIO_ENABLED_MANUAL=false
TWILIO_ENABLED_CCTV=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
EMERGENCY_CONTACT_NUMBER=+91XXXXXXXXXX
# Minimum seconds between calls (default 300 = 5 min); prevents call flooding from CCTV
TWILIO_CALL_COOLDOWN_SECONDS=300
# Camera list cache — hours before Iowa ArcGIS / Caltrans CSV is re-fetched from network.
# Set to 0 to always refetch on startup.
CAMERA_LIST_CACHE_TTL_HOURS=24

